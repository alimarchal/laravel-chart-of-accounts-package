{
    "name": "alimarchal/laravel-chart-of-accounts",
    "description": "A comprehensive Chart of Accounts and Accounting module for Laravel — supports Inertia/React and Blade/Livewire frontends, double-entry journal entries, multi-currency, financial reports, bank reconciliation, and more.",
    "keywords": ["laravel", "accounting", "chart-of-accounts", "journal-entries", "double-entry", "financial-reports", "livewire", "inertia"],
    "homepage": "https://github.com/alimarchal/laravel-chart-of-accounts-package",
    "license": "MIT",
    "authors": [
        {
            "name": "Ali Raza Marchal",
            "email": "alimarchal@gmail.com",
            "homepage": "https://github.com/alimarchal",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0",
        "illuminate/routing": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "pestphp/pest": "^2.0|^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0|^4.0"
    },
    "suggest": {
        "inertiajs/inertia-laravel": "Required for Inertia/React frontend (ui_driver=inertia)",
        "livewire/livewire": "Required for Blade/Livewire frontend (ui_driver=blade)",
        "spatie/laravel-permission": "Recommended for permission-based access control"
    },
    "autoload": {
        "psr-4": {
            "Alimarchal\\LaravelChartOfAccounts\\": "src/",
            "Alimarchal\\LaravelChartOfAccounts\\Database\\Factories\\": "database/factories/",
            "Alimarchal\\LaravelChartOfAccounts\\Database\\Seeders\\": "src/Database/Seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Alimarchal\\LaravelChartOfAccounts\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Alimarchal\\LaravelChartOfAccounts\\LaravelChartOfAccountsServiceProvider"
            ],
            "aliases": {}
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
